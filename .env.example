# Copy to .env.local for local development. Do not commit real secrets.

# ── Required on Vercel (SEO / sitemap / Open Graph / JSON-LD) ────────────────
NEXT_PUBLIC_SITE_URL=https://greatlanecarriers.com

# ── Required for form email delivery (Resend) ────────────────────────────────
# Without these, forms return an error in production/Vercel Preview — no fake success.
RESEND_API_KEY=
FORM_FROM_EMAIL=Great Lane Carriers <noreply@yourdomain.com>
FORM_TO_EMAIL=dispatch@yourdomain.com
FORM_RECRUITING_EMAIL=recruit@yourdomain.com

# Local dev: missing Resend config logs submissions to the server console instead.
# Display phone/emails/address: edit content/site-content.ts (not env vars).
